# ────────────────────────────────────────────────────────────
# App
# ────────────────────────────────────────────────────────────
APP_ENV=development                 # development | production
APP_PORT=8000
LOG_LEVEL=INFO

# JWT for auth (single-user v1)
JWT_SECRET=change-me-please
JWT_EXPIRES_HOURS=720

# AES-GCM key for encrypting PAT at rest (32 bytes, base64)
ENCRYPTION_KEY=change-me-base64-32-bytes

# ────────────────────────────────────────────────────────────
# Database
# ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agent

# ────────────────────────────────────────────────────────────
# Redis (queue + pubsub for SSE)
# ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ────────────────────────────────────────────────────────────
# GitHub
# ────────────────────────────────────────────────────────────
# PAT is set via UI per user. These are app-level config only.
GITHUB_API_BASE=https://api.github.com
GITHUB_REQUEST_TIMEOUT=30

# ────────────────────────────────────────────────────────────
# Codex CLI
# ────────────────────────────────────────────────────────────
CODEX_BINARY=codex
CODEX_DEFAULT_TIMEOUT=600
CODEX_MAX_LOC_DEFAULT=200

# ────────────────────────────────────────────────────────────
# Sandbox / working directory
# ────────────────────────────────────────────────────────────
WORKDIR=/var/agent/workdir
WORKDIR_GC_HOURS=24
WORKDIR_MAX_BYTES=10737418240        # 10 GB

# ────────────────────────────────────────────────────────────
# Pipeline tuning
# ────────────────────────────────────────────────────────────
MAX_CONCURRENT_RUNS=3                # parallel issue-fix runs
MAX_CONCURRENT_ONBOARDING=5          # parallel repo onboardings
BUFFER_MULTIPLIER=2.0                # median_review * this = buffer_days
BUFFER_MIN_DAYS=7
BUFFER_MAX_DAYS=21
BUFFER_GRACE_DAYS=5

# ────────────────────────────────────────────────────────────
# Health scoring thresholds
# ────────────────────────────────────────────────────────────
MIN_HEALTH_SCORE_TO_PROCEED=40

# ────────────────────────────────────────────────────────────
# Codex / agent identity (for git commits)
# ────────────────────────────────────────────────────────────
# These can also be per-user via DB; these are fallbacks.
GIT_COMMIT_NAME_FALLBACK=PatchPilot
GIT_COMMIT_EMAIL_FALLBACK=patchpilot@example.com

# ────────────────────────────────────────────────────────────
# Frontend (Next.js)
# ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ────────────────────────────────────────────────────────────
# Optional — only if you wire up Anthropic API directly
# (instead of or in addition to Codex CLI)
# ────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=
