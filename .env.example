# PatchPilot environment configuration

# --- Core ---
APP_ENV=local
LOG_LEVEL=INFO
API_PREFIX=/api/v1

# --- Database (SQLite, single-user) ---
DATABASE_URL=sqlite:///./data/patchpilot.db

# --- Redis (ARQ broker + log pubsub) ---
REDIS_URL=redis://localhost:6379/0

# --- Workspace ---
WORKDIR=./workspace

# --- GitHub PAT (env fallback; UI override stored encrypted in DB) ---
# Required scopes: repo, read:user, workflow
GITHUB_TOKEN=
GIT_COMMIT_NAME=PatchPilot
GIT_COMMIT_EMAIL=patchpilot@local

# --- Encryption (AES-GCM key for at-rest PAT storage; 32 bytes base64) ---
# Generate with: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=

# --- Codex ---
CODEX_BINARY=codex
CODEX_DEFAULT_TIMEOUT=600
CODEX_MAX_LOC_DEFAULT=200
# CODEX_FAKE_MODE=true returns canned diffs to avoid burning real credits
CODEX_FAKE_MODE=true

# --- Pipeline tuning ---
BUFFER_MULTIPLIER=2.0
BUFFER_MIN_DAYS=7
BUFFER_MAX_DAYS=21
GRACE_DAYS=5
MAX_CONCURRENT_RUNS=3
MIN_HEALTH_SCORE=40

# --- Single seeded user (no auth) ---
SEED_USER_EMAIL=local@patchpilot
SEED_USER_NAME=Local User
